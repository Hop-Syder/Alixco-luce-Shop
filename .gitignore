# ─── PYTHON (Backend) ────────────────────────────────────────

# Cache Python
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
wheels/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Environnements virtuels
.venv/
venv/
env/
ENV/

# uv
.python-version

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# pytest
.pytest_cache/
.coverage
htmlcov/

# Pyright / Pylance
pyrightconfig.json


# ─── NODE.JS / REACT / VITE (Frontend) ───────────────────────

# Dépendances
node_modules/

# Build Vite
dist/
dist-ssr/

# Logs npm/yarn/pnpm
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Cache
.cache/
.parcel-cache/
.turbo/

# Fichiers locaux
*.local


# ─── ÉDITEURS / IDE ──────────────────────────────────────────

# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (IntelliJ, PyCharm, WebStorm…)
.idea/
*.iml

# Vim / Neovim
*.suo
*.sw?
*.ntvs*
*.njsproj
*.sln
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# Emacs
*~
\#*\#


